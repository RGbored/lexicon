# dependencies
node_modules/

# generated by `npm run generate` (rebuilt on deploy)
data/characters.json

# bundled dictionary, built once from Alar via `npm run dictionary` (large)
data/dictionary.json

# runtime state (per-user, not source)
data/progress.json
data/texts-user.json

# SQLite database (per-user state) + one-time migration backups
data/lexicon.db
data/lexicon.db-wal
data/lexicon.db-shm
data/*.migrated

# logs
*.log
npm-debug.log*

# os / editor
.DS_Store
.idea/
.vscode/
